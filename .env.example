# ==========================================
# Interview Recorder — Environment Variables
# ==========================================
# Copy this file to .env and fill in values.

# --- Database ---
DATABASE_URL=postgresql://interview_user:interview_pass@localhost:5432/interview_recorder

# --- AWS / S3 (LocalStack for dev) ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_BUCKET_NAME=interview-recordings
S3_ENDPOINT=http://localhost:4566
S3_FORCE_PATH_STYLE=true

# --- API ---
API_PORT=3000
API_HOST=0.0.0.0

# --- Authentication (Tinyauth over HTTP + backend session JWT) ---
# Base URL of the Tinyauth credential store (HTTP - no HTTPS/Caddy/hosts).
# The backend validates interviewer credentials by calling
# `${TINYAUTH_URL}/api/auth/traefik`. Three dummy accounts are seeded via
# TINYAUTH_AUTH_USERS in docker-compose.yml (interviewer1/pass1, etc.).
TINYAUTH_URL=http://localhost:3001
# Secret used to sign/verify backend session JWTs (HS256).
# Generate a strong random secret for production:
#   openssl rand -base64 32
JWT_SECRET=<generate-a-strong-random-secret>
