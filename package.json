{
  "name": "interview-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Interview Recorder — React Native mobile app + Node.js backend",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "clean": "turbo run clean"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "turbo": "^2.10.3"
  }
}
