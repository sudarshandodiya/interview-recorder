# Metro (Expo's bundler) cannot resolve packages through pnpm's isolated
# `.pnpm` symlink layout — it expects a flat, hoisted node_modules like npm
# would produce. Without this, the mobile app fails to bundle with errors
# like "Unable to resolve module @babel/runtime/helpers/interopRequireDefault".
# See https://docs.expo.dev/guides/monorepos/ (pnpm + Metro guidance).
node-linker=hoisted